<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Profile — Ride Price Comparison</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/output.css" />
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans">
    <div class="max-w-6xl mx-auto px-6 py-10">
      <header class="flex items-center justify-between mb-8">
        <h1 class="text-2xl font-extrabold">Profile</h1>
        <div class="flex items-center gap-3">
          <a href="/" class="text-sm text-gray-600 hover:underline">Home</a>
          <div
            class="w-8 h-8 rounded-full bg-gray-900 text-white text-sm font-bold grid place-items-center"
          >
            DK
          </div>
        </div>
      </header>

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
        <!-- Sidebar -->
        <aside class="col-span-1 bg-white rounded-xl shadow p-6">
          <div class="flex flex-col items-center">
            <div
              id="avatarPreview"
              class="w-28 h-28 rounded-full bg-gradient-to-br from-indigo-500 to-pink-500 text-white text-3xl font-bold grid place-items-center"
            >
              DK
            </div>
            <h2 class="mt-4 text-lg font-semibold">Dipanshu Kumar</h2>
            <p class="text-sm text-gray-500">dipanshu@example.com</p>

            <div class="w-full mt-6 grid grid-cols-2 gap-3">
              <div class="p-3 bg-gray-50 rounded-lg text-center">
                <div class="text-xs text-gray-500">Points</div>
                <div class="text-xl font-bold text-amber-600">1240</div>
              </div>
              <div class="p-3 bg-gray-50 rounded-lg text-center">
                <div class="text-xs text-gray-500">Coupons</div>
                <div class="text-xl font-bold text-green-600">3</div>
              </div>
            </div>

            <div class="mt-6 w-full">
              <a
                href="/edit-profile"
                class="block w-full text-center px-4 py-2 rounded-md bg-gray-100 hover:bg-gray-200"
                >Edit profile</a
              >
              <form action="/logout" method="POST" class="mt-3">
                <button
                  type="submit"
                  class="w-full px-4 py-2 rounded-md bg-red-600 text-white hover:bg-red-700"
                >
                  Logout
                </button>
              </form>
            </div>
          </div>
        </aside>

        <!-- Main -->
        <main class="col-span-1 lg:col-span-3">
          <div class="bg-white rounded-xl shadow p-6">
            <!-- Tabs -->
            <div class="flex items-center justify-between">
              <nav class="flex gap-2" aria-label="Sections">
                <a
                  href="#overview"
                  class="px-4 py-2 rounded-md bg-indigo-50 text-indigo-600"
                  >Overview</a
                >
                <a href="#bookings" class="px-4 py-2 rounded-md text-gray-600"
                  >Bookings</a
                >
                <a href="#payments" class="px-4 py-2 rounded-md text-gray-600"
                  >Payments</a
                >
                <a href="#settings" class="px-4 py-2 rounded-md text-gray-600"
                  >Settings</a
                >
              </nav>
              <div class="text-sm text-gray-500">Member since 2024-09-01</div>
            </div>

            <div class="mt-6">
              <!-- Overview -->
              <section id="overview">
                <h3 class="text-lg font-semibold mb-3">Account overview</h3>
                <p class="text-gray-600">
                  Welcome back, Dipanshu — here's a quick summary of your
                  account.
                </p>

                <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-4">
                  <div class="p-4 bg-gray-50 rounded-lg">
                    <div class="text-xs text-gray-500">Total rides</div>
                    <div class="text-2xl font-bold">46</div>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-lg">
                    <div class="text-xs text-gray-500">Active coupons</div>
                    <div class="text-2xl font-bold">3</div>
                  </div>
                  <div class="p-4 bg-gray-50 rounded-lg">
                    <div class="text-xs text-gray-500">Pending payments</div>
                    <div class="text-2xl font-bold">₹0</div>
                  </div>
                </div>
              </section>

              <!-- Bookings -->
              <section id="bookings" class="mt-8">
                <h3 class="text-lg font-semibold mb-3">Recent bookings</h3>
                <div class="overflow-auto">
                  <table class="w-full text-sm">
                    <thead class="text-left text-gray-600">
                      <tr>
                        <th class="px-3 py-2">ID</th>
                        <th class="px-3 py-2">Date</th>
                        <th class="px-3 py-2">From → To</th>
                        <th class="px-3 py-2">Transport</th>
                        <th class="px-3 py-2">Amount</th>
                        <th class="px-3 py-2">Status</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr class="border-t">
                        <td class="px-3 py-2">#RB1024</td>
                        <td class="px-3 py-2">2026-04-08</td>
                        <td class="px-3 py-2">MG Road → Airport</td>
                        <td class="px-3 py-2">Car</td>
                        <td class="px-3 py-2">₹240</td>
                        <td class="px-3 py-2">
                          <span
                            class="px-2 py-1 rounded-full text-xs bg-green-100 text-green-700"
                            >Completed</span
                          >
                        </td>
                      </tr>
                      <tr class="border-t">
                        <td class="px-3 py-2">#RB1023</td>
                        <td class="px-3 py-2">2026-04-07</td>
                        <td class="px-3 py-2">Station → Office</td>
                        <td class="px-3 py-2">Train</td>
                        <td class="px-3 py-2">₹60</td>
                        <td class="px-3 py-2">
                          <span
                            class="px-2 py-1 rounded-full text-xs bg-yellow-100 text-yellow-700"
                            >Scheduled</span
                          >
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </section>

              <!-- Payments -->
              <section id="payments" class="mt-8">
                <h3 class="text-lg font-semibold mb-3">Payments</h3>
                <p class="text-gray-600">No recent payments.</p>
              </section>

              <!-- Settings -->
              <section id="settings" class="mt-8">
                <h3 class="text-lg font-semibold mb-3">Settings</h3>
                <form action="/update-profile" method="POST" class="grid gap-3">
                  <div>
                    <label class="text-xs text-gray-500">Full name</label>
                    <input
                      name="name"
                      value="Dipanshu Kumar"
                      class="w-full p-2 border rounded-md"
                    />
                  </div>
                  <div>
                    <label class="text-xs text-gray-500">Email</label>
                    <input
                      name="email"
                      value="dipanshu@example.com"
                      class="w-full p-2 border rounded-md"
                    />
                  </div>
                  <div class="flex gap-2">
                    <button
                      class="px-4 py-2 bg-indigo-600 text-white rounded-md"
                    >
                      Save changes
                    </button>
                    <a
                      href="/change-password"
                      class="px-4 py-2 border rounded-md text-sm"
                      >Change password</a
                    >
                  </div>
                </form>
              </section>
            </div>
          </div>
        </main>
      </div>

      <footer class="mt-10 text-center text-xs text-gray-500">
        © 2026 Ride Price Comparison — All rights reserved.
      </footer>
    </div>
  </body>
</html>
