<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Customer Care</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-100 text-gray-800 font-sans">
    <div class="max-w-3xl mx-auto px-5 py-8">
      <h1 class="text-2xl font-bold mb-4">Customer Care</h1>
      <p class="text-gray-600 mb-6">
        If you have any issues with a booking, payment, or account, please reach
        out to our customer care team.
      </p>

      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="font-semibold mb-2">Contact options</h2>
        <ul class="list-disc list-inside text-gray-700">
          <li>Email: support@minfare.example</li>
          <li>Phone: +91 98765 43210</li>
          <li>Available: 9:00 AM - 9:00 PM IST (Mon - Sun)</li>
        </ul>

        <div class="mt-4">
          <a
            href="/"
            class="inline-block px-4 py-2 bg-gray-900 text-white rounded"
            >Back to Home</a
          >
        </div>
      </div>
    </div>
  </body>
</html>
