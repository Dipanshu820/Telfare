<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Feedback</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-100 text-gray-800 font-sans">
    <div class="max-w-3xl mx-auto px-5 py-8">
      <h1 class="text-2xl font-bold mb-4">Feedback</h1>
      <p class="text-gray-600 mb-6">
        We'd love to hear from you. Share feedback about your experience.
      </p>

      <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="font-semibold mb-2">Leave feedback</h2>
        <p class="text-gray-700 mb-4">
          You can email us at feedback@minfare.example or use the app's feedback
          form (coming soon).
        </p>

        <div class="mt-4">
          <a
            href="/"
            class="inline-block px-4 py-2 bg-gray-900 text-white rounded"
            >Back to Home</a
          >
        </div>
      </div>
    </div>
  </body>
</html>
